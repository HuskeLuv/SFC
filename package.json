{
  "name": "front",
  "version": "2.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "seed": "npx tsx prisma/seed.ts",
    "sync-data": "npx tsx scripts/sync-external-data.ts",
    "sync-stocks": "npx tsx scripts/sync-stocks.ts",
    "ingest-benchmarks": "npx tsx scripts/ingest-benchmark-profitability.ts",
    "snapshots:portfolio": "npx tsx scripts/run-portfolio-snapshots.ts",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && next build",
    "clean": "rm -rf .next out dist",
    "type-check": "tsc --noEmit",
    "prepare": "husky || true"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
