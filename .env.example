# ─────────────────────────────────────────────────────────────────────
# Variáveis obrigatórias
# ─────────────────────────────────────────────────────────────────────

# PostgreSQL — connection string completa
# Local: postgresql://user:pass@localhost:5432/sfc?schema=public
# AWS RDS via Proxy: postgresql://user:pass@<rds-proxy-endpoint>:5432/sfc?sslmode=require
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Chave de assinatura JWT — gerar com: openssl rand -hex 64
JWT_SECRET="your-jwt-secret-key-here"

# Chave da BRAPI para cotações B3 — pegar em https://brapi.dev
BRAPI_API_KEY="your-brapi-api-key-here"

# Bearer token usado pelos endpoints /api/cron/* — gerar com: openssl rand -hex 32
# O EventBridge Scheduler (ou cron externo) envia este token em Authorization: Bearer <CRON_SECRET>
CRON_SECRET="your-cron-secret-here"

# ─────────────────────────────────────────────────────────────────────
# Variáveis opcionais
# ─────────────────────────────────────────────────────────────────────

# TTL (em ms) do cache server-side de /api/carteira/resumo. Default: 30000 (30s)
# CARTEIRA_RESUMO_CACHE_MS=30000

# Se "true", usa snapshots persistidos pra histórico de patrimônio em vez de rebuild ao vivo.
# Default: false (rebuild). Ativar quando snapshots estiverem populados em produção.
# USE_PORTFOLIO_SNAPSHOTS=false
