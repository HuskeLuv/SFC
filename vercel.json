{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm ci --include=dev",
  "devCommand": "npm run dev",
  "regions": ["gru1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "crons": [
    {
      "path": "/api/cron/economic-indexes",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/tesouro-direto-sync",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/cvm-fund-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/cvm-fund-history",
      "schedule": "45 6 * * 0"
    },
    {
      "path": "/api/cron/cvm-catalog-sync",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/brapi-sync/backfill-names",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/brapi-sync/catalog",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/brapi-sync/prices-other",
      "schedule": "5 7 * * *"
    },
    {
      "path": "/api/cron/brapi-sync/prices-stocks",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron/market-data/refresh",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/brapi-sync/dividends",
      "schedule": "20 7 * * *"
    },
    {
      "path": "/api/cron/apply-corporate-actions",
      "schedule": "25 7 * * *"
    },
    {
      "path": "/api/cron/brapi-sync/fundamentals",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/portfolio-snapshots",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/lgpd-retention",
      "schedule": "0 5 * * 0"
    }
  ]
}
