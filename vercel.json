{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["gru1"],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    },
    "app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NODE_ENV": "production"
    }
  },
  "crons": [
    {
      "path": "/api/cron/economic-indexes",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/tesouro-direto-sync",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/cron/cvm-fund-sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/cvm-catalog-sync",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/brapi-sync/catalog",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/brapi-sync/prices-other",
      "schedule": "5 7 * * *"
    },
    {
      "path": "/api/cron/brapi-sync/prices-stocks",
      "schedule": "10 7 * * *"
    },
    {
      "path": "/api/cron/portfolio-snapshots",
      "schedule": "0 8 * * *"
    }
  ]
}
