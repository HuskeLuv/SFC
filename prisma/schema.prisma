// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  consultant
  admin
}

enum ConsultantClientStatus {
  active
  inactive
}

enum ConsultantInviteStatus {
  pending
  accepted
  rejected
}

enum FixedIncomeType {
  CDB_PRE
  LC_PRE
  LCI_PRE
  LCA_PRE
  RDB_PRE
  LF_PRE
  LFS_PRE
  CRI_PRE
  CRA_PRE
  DPGE_PRE
  RDC_PRE
  LIG_PRE
  CDB_HIB
  LC_HIB
  LCI_HIB
  LCA_HIB
  RDB_HIB
  LF_HIB
  LFS_HIB
  CRI_HIB
  CRA_HIB
  DPGE_HIB
  RDC_HIB
  LIG_HIB
}

enum FixedIncomeIndexer {
  PRE
  CDI
  IPCA
}

enum FixedIncomeLiquidity {
  DAILY
  MATURITY
}

model User {
  id                            String                        @id @default(uuid())
  email                         String                        @unique
  password                      String
  name                          String
  avatarUrl                     String?
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  role                          UserRole                      @default(user)
  // LGPD #12: 2FA TOTP. totpSecret é base32 (RFC 4226). Hoje plain text;
  // débito técnico — migrar pra KMS-encrypted quando estiver em AWS.
  // totpEnabled = false durante o setup; só vira true depois que o user
  // confirma com código válido.
  totpSecret                    String?
  totpEnabled                   Boolean                       @default(false)
  events                        Event[]
  dashboard                     DashboardData[]
  cashflows                     Cashflow[]
  cashflowGroups                CashflowGroup[]
  cashflowItems                 CashflowItem[]
  cashflowValues                CashflowValue[]
  consultantProfile             Consultant?
  consultancies                 ClientConsultant[]            @relation("ClientConsultantClients")
  // Stocks
  watchlists                    Watchlist[]
  portfolios                    Portfolio[]
  stockTransactions             StockTransaction[]
  portfolioProventos            PortfolioProvento[]
  fixedIncomeAssets             FixedIncomeAsset[]
  notifications                 Notification[]
  consultantInvites             ConsultantInvite[]            @relation("UserConsultantInvites")
  impersonationLogsAsConsultant ConsultantImpersonationLog[]  @relation("ImpersonationLogConsultant")
  impersonationLogsAsClient     ConsultantImpersonationLog[]  @relation("ImpersonationLogClient")
  alocacaoConfigs               AlocacaoConfig[]
  portfolioDailySnapshots       PortfolioDailySnapshot[]
  portfolioPerformances         PortfolioPerformance[]
  sensibilidadeCaches           PortfolioSensibilidadeCache[]
  riscoRetornoCache             PortfolioRiscoRetornoCache?
  portfolioGoal                 PortfolioGoal?
  planejamentoObjetivos         PlanejamentoObjetivo[]
  aposentadoriaPlano            AposentadoriaPlano?
  consents                      UserConsent[]
  loginEvents                   LoginEvent[]
  changeLogs                    UserChangeLog[]               @relation("UserChangeLogUser")
  cashflowPatrimonioSnapshots   CashflowPatrimonioSnapshot[]  @relation("CashflowPatrimonioSnapshotUser")
}

/**
 * Registro de consentimento LGPD (Art. 8º §1º). Persiste o aceite do
 * usuário aos Termos de Uso e Política de Privacidade — exigência pra
 * que o consentimento seja juridicamente válido (informado, expresso,
 * rastreável).
 * Cada nova versão da política/termos gera novo registro (uma versão
 * vigente por documento). Revogação cria registro com `revokedAt` ≠ null
 * — mantemos histórico em vez de delete pra cumprir Art. 9º §2º.
 */
model UserConsent {
  id              String    @id @default(uuid())
  userId          String
  documentType    String // "privacy-policy" | "terms-of-use"
  documentVersion String // ex. "1.0"
  acceptedAt      DateTime  @default(now())
  ipAddress       String?
  userAgent       String?
  revokedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, documentType])
  @@map("user_consents")
}

model Consultant {
  id        String             @id @default(uuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id])
  clients   ClientConsultant[]
  invites   ConsultantInvite[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model ClientConsultant {
  id           String                 @id @default(uuid())
  consultantId String
  consultant   Consultant             @relation(fields: [consultantId], references: [id])
  clientId     String
  client       User                   @relation("ClientConsultantClients", fields: [clientId], references: [id])
  createdAt    DateTime               @default(now())
  status       ConsultantClientStatus @default(active)

  @@unique([consultantId, clientId])
  @@index([clientId])
}

model ConsultantInvite {
  id            String                 @id @default(uuid())
  consultantId  String
  consultant    Consultant             @relation(fields: [consultantId], references: [id])
  invitedUserId String?
  invitedUser   User?                  @relation("UserConsultantInvites", fields: [invitedUserId], references: [id])
  email         String
  status        ConsultantInviteStatus @default(pending)
  token         String                 @unique
  createdAt     DateTime               @default(now())
  respondedAt   DateTime?
  notifications Notification[]

  @@index([invitedUserId])
  @@index([consultantId])
}

model Notification {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime          @default(now())
  inviteId  String?
  invite    ConsultantInvite? @relation(fields: [inviteId], references: [id])

  @@index([userId, createdAt])
}

model Event {
  id     String   @id @default(uuid())
  title  String
  date   DateTime
  userId String
  user   User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model DashboardData {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  metric String
  value  Float

  @@index([userId])
}

model AlocacaoConfig {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  categoria String
  minimo    Float
  maximo    Float
  target    Float
  descricao String?  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoria])
  @@index([userId])
  @@map("alocacao_configs")
}

model Cashflow {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  data            DateTime
  tipo            String // "Receita" ou "Despesa"
  categoria       String
  descricao       String
  valor           Float
  forma_pagamento String
  pago            Boolean
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model CashflowGroup {
  id         String          @id @default(uuid())
  userId     String? // null se for grupo padrão (template)
  user       User?           @relation(fields: [userId], references: [id])
  name       String
  type       String // 'entrada', 'despesa' ou 'investimento'
  parentId   String? // FK para outro grupo (subgrupo)
  parent     CashflowGroup?  @relation("SubGroups", fields: [parentId], references: [id])
  children   CashflowGroup[] @relation("SubGroups")
  items      CashflowItem[]
  orderIndex Int             @default(0)
  // Override layer: quando setado, esta linha personaliza o template apontado.
  // Permite link estável entre override e template (mais robusto que match por nome).
  templateId String?
  template   CashflowGroup?  @relation("GroupOverride", fields: [templateId], references: [id])
  overrides  CashflowGroup[] @relation("GroupOverride")
  // Tombstone: usuário ocultou um template. Override row com hidden=true some do tree.
  hidden     Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, templateId])
  @@index([userId])
  @@index([parentId])
  @@index([templateId])
}

model CashflowItem {
  id          String         @id @default(uuid())
  userId      String? // null se for item padrão (template)
  user        User?          @relation(fields: [userId], references: [id])
  groupId     String
  group       CashflowGroup  @relation(fields: [groupId], references: [id])
  name        String
  significado String? // explicação opcional
  rank        String? // ordem de importância (essencial, normal, etc.)
  // Override layer: quando setado, esta linha personaliza o item-template apontado.
  templateId  String?
  template    CashflowItem?  @relation("ItemOverride", fields: [templateId], references: [id])
  overrides   CashflowItem[] @relation("ItemOverride")
  // Tombstone: usuário ocultou um item-template.
  hidden      Boolean        @default(false)
  // Vínculo opcional com um objetivo do Planejamento de Sonhos. Quando setado,
  // esta linha é espelho do sonho (somente-leitura no fluxo de caixa) e seus
  // valores mensais são o aporte mensal (pmt) sincronizado pelo planejamento.
  objetivoId  String?               @unique
  objetivo    PlanejamentoObjetivo? @relation(fields: [objetivoId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  values CashflowValue[]

  @@unique([userId, templateId])
  @@index([groupId])
  @@index([userId])
  @@index([templateId])
}

model CashflowValue {
  id        String       @id @default(uuid())
  itemId    String
  item      CashflowItem @relation(fields: [itemId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  year      Int
  month     Int // 0 = Jan, 11 = Dez
  value     Float
  color     String? // Cor do texto (formato CSS: #000000, green, red, etc.)
  comment   String? // Comentário da célula
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([itemId, userId, year, month])
  @@index([itemId])
  @@index([userId])
}

// ===== PORTFOLIO MODULE =====
// Pós-consolidação Stock → Asset (Sprint 5): `Stock` removido, ações/FIIs
// também vivem em `Asset` (type='stock' / 'fii'). FK única: assetId.

// Lista de observação do usuário
model Watchlist {
  id      String   @id @default(uuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id])
  assetId String?
  asset   Asset?   @relation(fields: [assetId], references: [id])
  addedAt DateTime @default(now())
  notes   String? // Observações do usuário

  @@index([userId])
  @@map("watchlists")
}

// Portfolio do usuário
model Portfolio {
  id            String              @id @default(uuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  assetId       String?
  asset         Asset?              @relation(fields: [assetId], references: [id])
  quantity      Float // Quantidade (Float para suportar criptomoedas com frações, ex: 0.000001 BTC)
  avgPrice      Float // Preço médio de compra
  totalInvested Float // Total investido
  objetivo      Float               @default(0) // Objetivo percentual do ativo
  estrategia    String? // Estratégia da ação: 'value', 'growth' ou 'risk'
  tipoFii       String? // Tipo do FII: 'fofi', 'tvm' ou 'tijolo'
  regiaoEtf     String? // Região do ETF: 'brasil' ou 'estados_unidos'
  lastUpdate    DateTime            @default(now())
  proventos     PortfolioProvento[]

  // Vínculo com planejamento (mutuamente exclusivos — validado na API):
  // sonho (FK) OU aposentadoria (flag; AposentadoriaPlano é 1 por usuário).
  // Aportes/resgates do ativo alimentam o realizado do plano vinculado e saem
  // das linhas automáticas do fluxo de caixa (evita dupla contagem).
  planejamentoObjetivoId String?
  planejamentoObjetivo   PlanejamentoObjetivo? @relation(fields: [planejamentoObjetivoId], references: [id], onDelete: SetNull)
  vinculoAposentadoria   Boolean               @default(false)

  @@unique([userId, assetId])
  @@index([userId])
  @@index([userId, assetId])
  @@index([userId, planejamentoObjetivoId])
  @@map("portfolios")
}

// Proventos registrados pelo usuário por posição na carteira (edição na tela de ativo)
model PortfolioProvento {
  id             String    @id @default(uuid())
  portfolioId    String
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo           String
  dataCom        DateTime
  dataPagamento  DateTime
  precificarPor  String    @default("valor")
  valorTotal     Float
  quantidadeBase Float
  impostoRenda   Float?
  // Soft delete: usuário deletou explicitamente. Sync respeita — não recria.
  dismissed      Boolean   @default(false)
  // Origem da entry: "brapi" (criada/atualizada pelo sync) ou "manual"
  // (criada/editada pelo usuário via UI). Sync atualiza só rows brapi.
  source         String    @default("manual")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([portfolioId])
  @@index([userId])
  @@map("portfolio_proventos")
}

// Histórico de transações (compras e vendas)
model StockTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  assetId   String?
  asset     Asset?   @relation(fields: [assetId], references: [id])
  type      String // "compra" ou "venda"
  quantity  Float // Quantidade (Float para suportar criptomoedas com frações)
  price     Float // Preço por ação
  total     Float // Valor total da transação
  date      DateTime // Data da transação
  fees      Float? // Taxas da operação
  notes     String? // Observações
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([userId, assetId, date])
  @@map("stock_transactions")
}

// ===== EXTERNAL DATA MODELS =====

// Ativos consolidados (ações, FII, ETF, BDR, REIT, criptos, etc.)
model Asset {
  id             String    @id @default(uuid())
  symbol         String    @unique // Código do ativo (ex: PETR4, VALE3, BTC, ETH)
  name           String // Nome do ativo (ex: Petrobras PN, Vale ON, Bitcoin)
  type           String // Tipo: "stock", "etf", "fii", "bdr", "crypto"
  currency       String // Moeda: "BRL", "USD"
  source         String    @default("brapi") // Fonte dos dados
  currentPrice   Decimal?  @db.Decimal(18, 6) // Preço atual; IBOV pode exceder 10^4
  priceUpdatedAt DateTime? // Data da última atualização de preço
  cnpj           String? // CNPJ para fundos — vincula a dados CVM
  categoria      String? // Fundos: Tipo_Classe da CVM (categoria nível 1)
  subcategoria   String? // Fundos: Classificacao da CVM (subcategoria nível 2)
  updatedAt      DateTime  @updatedAt

  // Relacionamentos
  watchlists       Watchlist[]
  portfolios       Portfolio[]
  transactions     StockTransaction[]
  fixedIncomeAsset FixedIncomeAsset?
  priceHistory     AssetPriceHistory[]

  @@index([symbol])
  @@index([type])
  @@index([source])
  @@index([cnpj])
  @@map("assets")
}

// Histórico de preços dos ativos (persistido pelo cron, lido pelas telas)
model AssetPriceHistory {
  id        String   @id @default(uuid())
  assetId   String
  symbol    String
  price     Decimal  @db.Decimal(18, 6) // IBOV e índices podem exceder 10^4
  currency  String?
  source    String   @default("BRAPI")
  date      DateTime // Data de referência (normalizada para início do dia)
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([symbol, date])
  @@index([symbol, date])
  @@index([symbol])
  @@index([date])
  @@map("asset_price_history")
}

// Histórico de proventos/dividendos (banco primeiro, fallback BRAPI com persistência)
model AssetDividendHistory {
  id            String    @id @default(uuid())
  symbol        String
  date          DateTime // Data de pagamento do provento (paymentDate na BRAPI)
  dataCom       DateTime? // Data-com / ex-dividend date — elegibilidade do investidor
  tipo          String // "Dividendo", "JCP", etc.
  valorUnitario Float // Valor por cota/ação
  source        String    @default("BRAPI")
  createdAt     DateTime  @default(now())

  @@unique([symbol, date, tipo])
  @@index([symbol])
  @@index([symbol, date])
  @@index([symbol, dataCom])
  @@map("asset_dividend_history")
}

// Ações corporativas: desdobramento (split), grupamento (inplit), bonificação
model AssetCorporateAction {
  id             String   @id @default(uuid())
  symbol         String
  date           DateTime // Data ex (lastDatePrior) ou data de aprovação
  type           String // "DESDOBRAMENTO" | "GRUPAMENTO" | "BONIFICACAO"
  factor         Float // 2.0 para split 2:1, 0.5 para grupamento 1:2
  completeFactor String? // "2 para 1" (legível)
  isinCode       String?
  source         String   @default("BRAPI")
  createdAt      DateTime @default(now())

  @@unique([symbol, date, type])
  @@index([symbol])
  @@index([symbol, date])
  @@map("asset_corporate_actions")
}

// Fundamentos do ativo (P/L, Beta, Dividend Yield) - banco primeiro, fallback BRAPI
model AssetFundamentals {
  id            String   @id @default(uuid())
  symbol        String   @unique
  priceEarnings Float? // P/L
  beta          Float?
  dividendYield Float? // Em %
  updatedAt     DateTime @updatedAt

  @@map("asset_fundamentals")
}

// Cobertura de dados de mercado por símbolo: registro de status do backfill,
// checkpoint de resumabilidade e fila de gaps de runtime. Permite que o runtime
// leia SÓ do banco (sem fallback externo no request) — quando um símbolo falta,
// registra-se um gap aqui e o backfill background o drena.
model MarketDataCoverage {
  id             String    @id @default(uuid())
  symbol         String    @unique
  // 'OK' (tem dados) | 'EMPTY' (fonte buscada, ativo genuinamente sem provento/evento)
  // | 'FETCH_FAIL' (não conseguiu buscar — retry) | 'GAP_QUEUED' (faltou em runtime)
  status         String
  dividendCount  Int       @default(0)
  caCount        Int       @default(0)
  lastCheckedAt  DateTime? // última vez que o backfill processou o símbolo (cursor/resume)
  gapRequestedAt DateTime? // setado pelo runtime quando o símbolo falta
  lastError      String?
  source         String? // 'backfill' | 'runtime-gap' | 'catalog-hook' | 'add-flow'
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([gapRequestedAt])
  @@index([lastCheckedAt])
  @@map("market_data_coverage")
}

// Log opcional de execução do sync de preços
model SyncPriceLog {
  id            String   @id @default(uuid())
  totalUpdated  Int      @default(0)
  totalInserted Int      @default(0)
  errors        Int      @default(0)
  duration      Int // segundos
  executedAt    DateTime @default(now())

  @@index([executedAt])
  @@map("sync_price_logs")
}

model FixedIncomeAsset {
  id              String                @id @default(uuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  assetId         String                @unique
  asset           Asset                 @relation(fields: [assetId], references: [id])
  type            FixedIncomeType
  description     String
  startDate       DateTime
  maturityDate    DateTime
  investedAmount  Float
  annualRate      Float
  indexer         FixedIncomeIndexer?
  indexerPercent  Float?
  liquidityType   FixedIncomeLiquidity?
  taxExempt       Boolean               @default(false)
  tesouroBondType String? // "Tesouro Selic", "Tesouro IPCA+", etc. — vincula a TesouroDiretoPrice
  tesouroMaturity DateTime? // Vencimento do titulo Tesouro — vincula a TesouroDiretoPrice
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([userId])
  @@index([assetId])
  @@map("fixed_income_assets")
}

// Enum para status das instituições
enum InstitutionStatus {
  ATIVA
  INATIVA
}

// Instituições financeiras (corretoras e bancos de investimento)
model Institution {
  id        String            @id @default(cuid())
  codigo    String            @unique // Código identificador da instituição
  nome      String // Nome da instituição
  cnpj      String? // CNPJ da instituição (opcional)
  status    InstitutionStatus @default(ATIVA)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([codigo])
  @@index([cnpj])
  @@index([status])
  @@map("institutions")
}

model ConsultantImpersonationLog {
  id           String   @id @default(uuid())
  consultantId String
  consultant   User     @relation("ImpersonationLogConsultant", fields: [consultantId], references: [id])
  clientId     String
  client       User     @relation("ImpersonationLogClient", fields: [clientId], references: [id])
  action       String
  details      Json
  ipAddress    String?
  userAgent    String?
  sessionToken String?
  createdAt    DateTime @default(now())

  @@index([consultantId])
  @@index([clientId])
  @@index([createdAt])
  @@index([action])
  @@index([sessionToken])
  @@map("consultant_impersonation_logs")
}

model ImpersonationSession {
  id           String    @id @default(uuid())
  sessionToken String    @unique
  consultantId String
  clientId     String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  endedAt      DateTime?

  @@index([consultantId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@map("impersonation_sessions")
}

/**
 * Histórico de alterações visível ao usuário: registra edições feitas na
 * conta (pelo próprio usuário ou por consultor impersonando), categorizadas
 * por seção do app. `changes` guarda os pares antes/depois já filtrados por
 * allowlist — nunca senhas, hashes ou segredos TOTP. Retenção: 365 dias
 * (cron lgpd-retention).
 */
model UserChangeLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation("UserChangeLogUser", fields: [userId], references: [id], onDelete: Cascade)
  actorId       String?
  viaConsultant Boolean  @default(false)
  section       String
  action        String
  entity        String?
  entityId      String?
  entityLabel   String?
  changes       Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, section, createdAt])
  @@map("user_change_logs")
}

/**
 * Snapshot mensal da linha "Evolução do Patrimônio" do fluxo de caixa.
 * Gravado pelo cron no último dia útil de cada mês (regra Pedro Haddad):
 * trava o valor calculado (aportes nominais + fluxo livre) para que meses
 * fechados fiquem estáticos no histórico, imunes a edições retroativas.
 */
model CashflowPatrimonioSnapshot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("CashflowPatrimonioSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  month     Int // 0 = janeiro ... 11 = dezembro
  valor     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year])
  @@map("cashflow_patrimonio_snapshots")
}

// ===== ECONOMIC INDEXES MODULE =====


model EconomicIndex {
  id        String   @id @default(uuid())
  indexType String // "CDI" | "IPCA"
  date      DateTime // Data de referência
  value     Decimal  @db.Decimal(14, 6) // Taxa do período ou valor absoluto de índice (IMA-B pode exceder 9999)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([indexType, date])
  @@index([indexType])
  @@index([date])
  @@index([indexType, date])
  @@map("economic_indexes")
}

// Cache de indicadores de mercado (IBOV, Dólar, BTC, ETH)
// Banco primeiro, fallback BRAPI quando cache expirado
model MarketIndicatorCache {
  id            String   @id @default(uuid())
  indicatorKey  String   @unique // "IBOV" | "USD-BRL" | "BTC" | "ETH"
  price         Decimal  @db.Decimal(18, 4)
  changePercent Decimal? @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt

  @@map("market_indicator_cache")
}

// Snapshot diário de patrimônio (pré-calculado pelo job; leitura rápida no resumo)
model PortfolioDailySnapshot {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime // início do dia (UTC/local consistente com o restante do app)
  totalValue    Decimal  @db.Decimal(18, 4) // saldo bruto
  totalInvested Decimal  @db.Decimal(18, 4) // valor aplicado
  totalEarnings Decimal  @db.Decimal(18, 4) // rendimentos acumulados (proventos no caixa do modelo)
  createdAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("portfolio_daily_snapshots")
}

// Cache da "Sensibilidade da Carteira" (correlação ativo↔carteira + MRC).
// Invalidado por portfolioHash (mudança de composição) ou por idade (TTL na leitura).
model PortfolioSensibilidadeCache {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  windowMonths  Int // janela solicitada (12..60)
  portfolioHash String // sha256 de (symbol:quantity:avgPrice) ordenado
  payload       Json // SensibilidadeCarteiraResponse serializado
  computedAt    DateTime @default(now())

  @@unique([userId, windowMonths])
  @@index([userId])
  @@map("portfolio_sensibilidade_cache")
}

// Cache do payload completo de /api/analises/risco-retorno. Invalida quando a
// composição da carteira (hash de symbol:quantity:avgPrice) muda, com TTL de 24h.
model PortfolioRiscoRetornoCache {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioHash String // sha256 de (symbol:quantity:avgPrice) ordenado
  payload       Json // RiscoRetornoResponse serializado
  computedAt    DateTime @default(now())

  @@map("portfolio_risco_retorno_cache")
}

// Meta de patrimônio do usuário: "alcançar R$ X até ano Y". Singleton por userId.
model PortfolioGoal {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetEquity Decimal  @db.Decimal(15, 2) // patrimônio alvo em BRL
  targetYear   Int // ano-alvo (ex.: 2030); cálculo de cronograma assume dezembro
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("portfolio_goals")
}

// TWR pré-calculado por dia (alinha ao historicoTWR do resumo)
model PortfolioPerformance {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  dailyReturn      Decimal? @db.Decimal(14, 8) // fração diária (ex.: 0.0012)
  cumulativeReturn Decimal  @db.Decimal(14, 6) // % acumulada TWR
  createdAt        DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("portfolio_performance")
}

// Preços diários de títulos do Tesouro Direto (fonte: Tesouro Transparente)
model TesouroDiretoPrice {
  id           String   @id @default(uuid())
  bondType     String // "Tesouro Selic", "Tesouro IPCA+", "Tesouro Prefixado", etc.
  maturityDate DateTime // Data de vencimento do título
  baseDate     DateTime // Data base da cotação
  buyRate      Decimal? @db.Decimal(10, 6) // Taxa compra manhã (% a.a.)
  sellRate     Decimal? @db.Decimal(10, 6) // Taxa venda manhã (% a.a.)
  buyPU        Decimal? @db.Decimal(18, 6) // PU compra manhã (R$)
  sellPU       Decimal? @db.Decimal(18, 6) // PU venda manhã (R$)
  basePU       Decimal? @db.Decimal(18, 6) // PU base manhã (R$)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([bondType, maturityDate, baseDate])
  @@index([bondType, maturityDate])
  @@index([baseDate])
  @@map("tesouro_direto_prices")
}

// Cotas diárias de fundos de investimento (fonte: CVM Dados Abertos)
model CvmFundQuota {
  id           String   @id @default(uuid())
  cnpj         String // CNPJ do fundo (14 dígitos, sem formatação)
  date         DateTime // DT_COMPTC — data de referência da cota
  quotaValue   Decimal  @db.Decimal(18, 8) // VL_QUOTA — valor da cota (alta precisão)
  netWorth     Decimal? @db.Decimal(18, 2) // VL_PATRIM_LIQ — patrimônio líquido
  totalValue   Decimal? @db.Decimal(18, 2) // VL_TOTAL — valor total da carteira
  shareholders Int? // NR_COTST — número de cotistas
  dailyInflow  Decimal? @db.Decimal(18, 2) // CAPTC_DIA — captação do dia
  dailyOutflow Decimal? @db.Decimal(18, 2) // RESG_DIA — resgate do dia
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([cnpj, date])
  @@index([cnpj])
  @@index([date])
  @@map("cvm_fund_quotas")
}

// Objetivos financeiros do usuário (F3 — Planejamento Sonhos).
// Substitui o simulador de aposentadoria. Cada objetivo é uma meta financeira
// com prazo, valor desejado, valor inicial e rentabilidade esperada.
//
// O `category` é uma classificação por prazo (curto/médio/longo) — derivada de
// `months` mas armazenada pra evitar recalcular em filtros frequentes.
model PlanejamentoObjetivo {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // "Reserva de Emergência", "Comprar Casa", etc.
  target    Decimal  @db.Decimal(15, 2) // Valor meta (R$)
  months    Int // Prazo em meses (1-480)
  startDate String? // YYYY-MM — opcional pra objetivos não iniciados
  available Decimal  @default(0) @db.Decimal(15, 2) // Valor disponível hoje
  rate      Decimal  @default(0) @db.Decimal(8, 6) // Rentabilidade ao mês (decimal: 0.01 = 1%)
  priority  String // "Alta" | "Moderado" | "Baixa"
  category  String // "c" (curto ≤12m) | "m" (médio 12-60m) | "l" (longo >60m)
  status    String // "Em espera" | "Iniciado" | "Pausado" | "Atrasado" | "Concluído"
  notes     String? // Observações livres
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries PlanejamentoObjetivoEntry[]
  // Linha espelhada no fluxo de caixa (grupo "Planejamento Financeiro"). O
  // sonho é a fonte: o aporte mensal (pmt) é gravado nessa linha.
  cashflowItem CashflowItem?

  // Ativos da carteira vinculados a este sonho (realizado automático).
  portfolios Portfolio[]

  @@index([userId])
  @@index([userId, category])
  @@map("planejamento_objetivos")
}

// Registros mensais de progresso de um objetivo.
// Cada entrada captura o estado em um mês específico (saldo + aporte realizado),
// permitindo comparar com o planejado (calculado via PMT) e desenhar a evolução.
model PlanejamentoObjetivoEntry {
  id         String               @id @default(uuid())
  objetivoId String
  objetivo   PlanejamentoObjetivo @relation(fields: [objetivoId], references: [id], onDelete: Cascade)
  month      String // YYYY-MM
  aporte     Decimal              @db.Decimal(15, 2) // Aporte realizado no mês
  balance    Decimal              @db.Decimal(15, 2) // Saldo ao fim do mês
  // "manual" = digitado no modal "Registrar Mês"; "auto" = derivado das células
  // verdes (realizadas) da linha-espelho no fluxo de caixa. Manual tem
  // precedência: o sync caixa→sonho nunca sobrescreve/remove entries manuais.
  source     String               @default("manual")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([objetivoId, month])
  @@index([objetivoId])
  @@map("planejamento_objetivo_entries")
}

// Simulador de Aposentadoria (inspirado no protótipo "Planejamento completo").
// Um plano por usuário: parâmetros de projeção em termos reais (acumulação →
// saque) + acompanhamento mensal em termos nominais. Convive com o CRUD de
// objetivos (Sonhos) — são features separadas dentro de /planejamento-financeiro.
//
// `eventos` é um Json com aportes/resgates pontuais: [{ tipo, idade, valor }].
// Mantido como Json (não tabela) porque é uma lista curta editada em bloco
// junto com o resto dos parâmetros — espelha o estado único do protótipo.
model AposentadoriaPlano {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Perfil
  idade Int // idade atual
  apos  Int // idade de aposentadoria
  vida  Int // expectativa de vida

  // Taxas (% ao ano)
  rentNom       Decimal  @db.Decimal(6, 3) // rentabilidade nominal a.a.
  inflacao      Decimal  @db.Decimal(6, 3) // inflação esperada a.a.
  rentNomRetiro Decimal? @db.Decimal(6, 3) // taxa nominal na aposentadoria (null = igual à acumulação)

  // Acumulação / renda (R$ de hoje)
  patrimonio Decimal @db.Decimal(15, 2) // patrimônio inicial
  aporteM    Decimal @db.Decimal(15, 2) // aporte mensal
  renda      Decimal @db.Decimal(15, 2) // renda desejada na aposentadoria

  // Início do acompanhamento
  trackStartMonth Int // 1-12
  trackStartYear  Int

  // Eventos pontuais: [{ tipo: 'aporte'|'resgate', idade: number, valor: number }]
  eventos Json @default("[]")

  // Campos travados manualmente pelo usuário (override): não re-sincronizam do
  // contexto financeiro (carteira/fluxo de caixa). Ex.: ["aporteM","renda"].
  // Campos auto (ausentes daqui) refletem os dados ao vivo.
  fieldLocks Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries AposentadoriaPlanoEntry[]

  @@map("aposentadoria_planos")
}

// Registro mensal de acompanhamento do plano de aposentadoria.
// `off` é o offset em meses a partir de (trackStartMonth/trackStartYear);
// year/month são desnormalizados pra exibição estável.
model AposentadoriaPlanoEntry {
  id         String             @id @default(uuid())
  planoId    String
  plano      AposentadoriaPlano @relation(fields: [planoId], references: [id], onDelete: Cascade)
  off        Int // mês do plano (1 = primeiro mês após o início)
  year       Int
  month      Int // 1-12
  aporteReal Decimal            @db.Decimal(15, 2) // aporte realizado no mês
  patFinal   Decimal            @db.Decimal(15, 2) // patrimônio ao fim do mês
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([planoId, off])
  @@index([planoId])
  @@map("aposentadoria_plano_entries")
}

// Trilha de auditoria de autenticação (login tracking).
// Append-only: cada tentativa de login (sucesso OU falha) gera uma linha.
// Falhas em conta inexistente têm userId=null mas email preenchido, pra
// rastrear ataques de enumeração/brute-force por e-mail.
//
// LGPD: ipAddress + userAgent são PII de segurança (legítimo interesse,
// Art. 7º IX). Retenção de 90 dias aplicada pelo cron lgpd-retention.
model LoginEvent {
  id        String   @id @default(uuid())
  userId    String? // null quando o e-mail não corresponde a nenhuma conta
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String // e-mail tentado (sempre gravado)
  success   Boolean
  // motivo da falha: "user_not_found" | "bad_password" | "totp_required"
  // | "totp_invalid" (null em sucesso)
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([createdAt])
  @@map("login_events")
}
